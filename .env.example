# --- Supabase ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_service_role_key

# --- Google Places API (New) ---
GOOGLE_PLACES_API_KEY=

# --- Motor de búsqueda: auto | places | maps ---
SEARCH_ENGINE=auto

# --- LLM principal (compatible con API de OpenAI) ---
LLM_API_KEY=
LLM_BASE_URL=https://api.cerebras.ai/v1
LLM_MODEL=gpt-oss-120b

# --- LLM fallbacks (opcionales, se suman a la rotación) ---
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_FALLBACK_MODEL=deepseek-ai/deepseek-v4-flash

LLM_FALLBACK2_API_KEY=
LLM_FALLBACK2_BASE_URL=https://api.groq.com/openai/v1
LLM_FALLBACK2_MODEL=llama-3.1-8b-instant

LLM_FALLBACK3_API_KEY=
LLM_FALLBACK3_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_FALLBACK3_MODEL=gemini-2.5-flash-lite

# --- Google Sheets ---
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/credentials.json
# Solo en Railway: el JSON completo de la cuenta de servicio en una línea
# GOOGLE_SHEETS_CREDENTIALS_JSON=

# --- Ajustes de producción (Railway) ---
# MAX_CONCURRENT_PAGES=1
# BROWSER_RESTART_AFTER=200
# LOG_LEVEL=INFO

# --- Fases del orquestador (Railway) ---
# RUN_SEARCH=false
# RUN_SCRAPE=true
# RUN_CLASSIFY=true
# RUN_SYNC=true
